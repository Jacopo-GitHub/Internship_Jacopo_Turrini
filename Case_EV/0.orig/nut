FoamFile
{
    format      binary;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];
internalField   uniform 0; 

boundaryField
{
    "(inlet|outlet|vent_out_diffuser)"
    {
        type            calculated;
        value           uniform 0; 
    }

    "(symmetry|symmetry_side|symmetry_up)"
    {
        type            symmetry; 
    }

    road
    {
        type            nutkRoughWallFunction;
        Ks              uniform 0.0005; 
        Cs              uniform 0.5; 
        value           uniform 0;
    }

    // Tutte le superfici della vettura con funzione di parete Spalding
"(monocoque|seat|main_hoop|headrest|driver|underbody|air_tank|front_suspension|rear_suspension|electric_motor_.*|wheel_.*|chassis_wing|front_supports|front_wing_.*|undertray_.*|rear_support|rear_wing_.*|vent_diffuser|diffuser_duct)"    {
        type            nutUSpaldingWallFunction;
        value           uniform 0; 
    }
}
