FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

// Velocità di riferimento basata sui log precedenti
internalField   uniform (-15.56 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            zeroGradient;
    }

    road
    {
        type            fixedValue;
        value           $internalField;
    }

    // Patch di simmetria identificate nel file boundary 
    "(symmetry|symmetry_side|symmetry_up)"
    {
        type            symmetry;
    }

    // Patch ventola con velocità specifica richiesta
    vent_out_diffuser
    {
        type            fixedValue;
        value           uniform (-4.8 0 0);
    }

    // Ruote Anteriori (rim, hub, tyre, patch) [cite: 53, 56, 59, 62]
    "wheel_front_.*"
    {
        type            rotatingWallVelocity;
        origin          (1.530290041 0.720400982 0.196911951);
        axis            (0 1 0);
        omega           79.020089;
        value           uniform (0 0 0);
    }

    // Ruote Posteriori (rim, hub, tyre, patch) [cite: 95, 98, 101, 104]
    "wheel_rear_.*"
    {
        type            rotatingWallVelocity;
        origin          (0.000038 0.712661827 0.199599865);
        axis            (0 1 0);
        omega           79.020089;
        value           uniform (0 0 0);
    }

    // Tutte le restanti patch fisiche dell'auto (No-Slip) [cite: 26, 143]
    "(monocoque|underbody|driver|seat|headrest|main_hoop|air_tank|front_suspension|electric_motor_front|chassis_wing|front_supports|front_wing_.*|undertray_.*|rear_suspension|electric_motor_rear|rear_support|rear_wing_.*|vent_diffuser|diffuser_duct)"
    {
        type            noSlip;
    }
}

