FoamFile
{
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

solver          incompressibleFluid;

startFrom       latestTime;

stopAt          endTime;

endTime         2000;

deltaT          1;

writeControl    timeStep;

writeInterval   250;

purgeWrite      3;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    // --- FORZE TOTALI (Tutta la vettura) ---
    forces_total
    {
        type            forces;
        libs            ("libforces.so");
        patches         (
            "monocoque"
            "seat"
            "main_hoop"
            "driver"
            "underbody"
            "air_intake"
            "chassis_wing"
            "sidepod"
            "radiator_frame"
            "front_suspensions"
            "rear_suspensions"
            "electric_motor"
            "wheel_front_patch"
            "wheel_front_tyre"
            "wheel_front_hub"
            "wheel_front_rim"
            "wheel_rear_patch"
            "wheel_rear_tyre"
            "wheel_rear_hub"
            "wheel_rear_rim"
            "front_wing_endplates"
            "front_wing_support"
            "front_wing_diveplanes"
            "front_wing_flap_2_3"
            "front_wing_flap_1"
            "front_wing_mainplane"
            "front_wing_strakes"
            "undertray_venturi"
            "venturi_flap_1"
            "venturi_flap_2"
            "venturi_plates"
            "rear_wing_endplate"
            "rear_wing_mainplane"
            "rear_wing_upper_flaps"
            "rear_wing_flap_2"
            "rear_wing_flap_1"
            "rear_wing_support"
        );
        rho             rhoInf;
        rhoInf          1.225;
        CofR            (0.747 0.005 0.257);
        log             true;
        writeControl    timeStep;
        writeInterval   5;
    }

    // --- ALA ANTERIORE ---
    forces_FW
    {
        type            forces;
        libs            ("libforces.so");
        patches         (
            "front_wing_endplates"
            "front_wing_support"
            "front_wing_diveplanes"
            "front_wing_flap_2_3"
            "front_wing_flap_1"
            "front_wing_mainplane"
            "front_wing_strakes"
        );
        rho             rhoInf;
        rhoInf          1.225;
        CofR            (0.747 0.005 0.257);
        log             true;
        writeControl    timeStep;
        writeInterval   5;
    }

    // --- ALA POSTERIORE ---
    forces_RW
    {
        type            forces;
        libs            ("libforces.so");
        patches         (
            "rear_wing_endplate"
            "rear_wing_mainplane"
            "rear_wing_upper_flaps"
            "rear_wing_flap_2"
            "rear_wing_flap_1"
            "rear_wing_support"
        );
        rho             rhoInf;
        rhoInf          1.225;
        CofR            (0.747 0.005 0.257);
        log             true;
        writeControl    timeStep;
        writeInterval   5;
    }

    // --- FONDO E VENTURI ---
    forces_undertray
    {
        type            forces;
        libs            ("libforces.so");
        patches         (
            "undertray_venturi"
            "venturi_flap_1"
            "venturi_flap_2"
            "venturi_plates"
        );
        rho             rhoInf;
        rhoInf          1.225;
        CofR            (0.747 0.005 0.257);
        log             true;
        writeControl    timeStep;
        writeInterval   5;
    }

    // --- SIDEPOD + RADIATORE (solo pareti esterne) ---
    forces_sidepod
    {
        type            forces;
        libs            ("libforces.so");
        patches         (
            "sidepod"
            "radiator_frame"
            "porous_media_walls"
        );
        rho             rhoInf;
        rhoInf          1.225;
        CofR            (0.747 0.005 0.257);
        log             true;
        writeControl    timeStep;
        writeInterval   5;
    }

    // Cp statico
    staticCoefficient
    {
        type            pressure;
        libs            (fieldFunctionObjects);
        mode            staticCoeff;
        p               p;
        U               U;
        pInf            0;
        pRef            0;
        rho             rhoInf;
        rhoInf          1;
        UInf            (-15.56 0 0);
        calcCoeff       yes;
        calcTotal       no;
        hydroStaticMode none;
        result          cp;
        executeControl  writeTime;
        writeControl    writeTime;
    }

    // Pressione totale
    totalPressurecoefficient
    {
        type            pressure;
        libs            ("libfieldFunctionObjects.so");
        mode            total;
        pRef            0;
        pInf            0;
        UInf            (-15.56 0 0);
        p               p;
        U               U;
        rho             rhoInf;
        rhoInf          1.225;
        calcCoeff       no;
        calcTotal       yes;
        result          ptot;
        executeControl  writeTime;
        writeControl    writeTime;
    }

    // Vorticità
    vorticity
    {
        type            vorticity;
        libs            ("libfieldFunctionObjects.so");
        executeControl  writeTime;
        writeControl    writeTime;
    }

    // Coefficienti globali
    Coeffs
    {
        type            forceCoeffs;
        libs            ("libforces.so");
        writeControl    timeStep;
        writeInterval   5;
        patches         (
            "monocoque"
            "seat"
            "main_hoop"
            "driver"
            "underbody"
            "air_intake"
            "chassis_wing"
            "sidepod"
            "radiator_frame"
            "front_suspensions"
            "rear_suspensions"
            "electric_motor"
            "wheel_front_patch"
            "wheel_front_tyre"
            "wheel_front_hub"
            "wheel_front_rim"
            "wheel_rear_patch"
            "wheel_rear_tyre"
            "wheel_rear_hub"
            "wheel_rear_rim"
            "front_wing_endplates"
            "front_wing_support"
            "front_wing_diveplanes"
            "front_wing_flap_2_3"
            "front_wing_flap_1"
            "front_wing_mainplane"
            "front_wing_strakes"
            "undertray_venturi"
            "venturi_flap_1"
            "venturi_flap_2"
            "venturi_plates"
            "rear_wing_endplate"
            "rear_wing_mainplane"
            "rear_wing_upper_flaps"
            "rear_wing_flap_2"
            "rear_wing_flap_1"
            "rear_wing_support"
        );
        rho             rhoInf;
        rhoInf          1.225;
        magUInf         15.56;
        dragDir         (-1 0 0);
        liftDir         (0 0 1);
        CofR            (0.747 0.005 0.257);
        pitchAxis       (0 1 0);
        lRef            1.4;
        Aref            1.1;
    }
}

// ************************************************************************* //
